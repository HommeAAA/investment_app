<view class="page login-page">
  <view class="login-header">
    <view class="logo-wrap">
      <view class="logo">💰</view>
    </view>
    <view class="app-name">投资管家</view>
    <view class="app-desc">智能管理您的投资组合</view>
  </view>

  <view class="card login-card fade-in">
    <view class="card-header">
      <view class="title">微信登录</view>
      <view class="sub">首次登录会自动创建账号</view>
    </view>
    
    <button class="btn btn-primary login-btn" bindtap="onWechatLogin" loading="{{loadingLogin}}">
      <text class="btn-icon">🔐</text>
      <text>微信一键登录</text>
    </button>
    
    <view class="divider">
      <text class="divider-text">或</text>
    </view>
    
    <button class="btn btn-secondary" bindtap="onCheckCloud" loading="{{loadingCheck}}">
      <text class="btn-icon">🔧</text>
      <text>测试云函数连接</text>
    </button>
  </view>

  <view class="card bind-card fade-in" wx:if="{{user && !user.boundLegacy}}">
    <view class="card-header">
      <view class="title">绑定旧账号</view>
      <view class="sub">迁移历史数据（可选）</view>
    </view>
    
    <view class="form-group">
      <view class="form-label">旧用户名</view>
      <input class="input" placeholder="请输入旧账号用户名" value="{{legacyUsername}}" bindinput="onLegacyUsernameInput" />
    </view>
    
    <view class="form-group">
      <view class="form-label">旧密码</view>
      <input class="input" password="true" placeholder="请输入旧账号密码" value="{{legacyPassword}}" bindinput="onLegacyPasswordInput" />
    </view>
    
    <button class="btn btn-primary" bindtap="onBindLegacy" loading="{{loadingBind}}">
      <text class="btn-icon">🔗</text>
      <text>绑定并迁移</text>
    </button>
  </view>

  <view class="card success-card fade-in" wx:if="{{user && user.boundLegacy}}">
    <view class="success-header">
      <view class="success-icon">✅</view>
      <view class="title">已登录</view>
    </view>
    <view class="user-info">
      <view class="info-row">
        <text class="info-label">昵称</text>
        <text class="info-value">{{user.nickname}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">邀请码</text>
        <text class="info-value badge badge-primary">{{user.inviteCode}}</text>
      </view>
    </view>
    <button class="btn btn-primary" bindtap="goPortfolio">
      <text class="btn-icon">📊</text>
      <text>进入资产页</text>
    </button>
  </view>
</view>
