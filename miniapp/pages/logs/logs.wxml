<view class="page">
  <view class="card">
    <view class="title">操作日志</view>
    <button size="mini" bindtap="loadLogs" loading="{{loading}}">刷新</button>
  </view>

  <view class="card" wx:if="{{rows.length===0}}">
    <view class="sub">暂无日志</view>
  </view>

  <block wx:for="{{rows}}" wx:key="_id">
    <view class="card">
      <view class="line">
        <text>{{item.action}}</text>
        <text class="sub">{{item.actionTime}}</text>
      </view>
      <view class="sub">类型：{{item.entityType}} / ID：{{item.entityId}}</view>
      <view class="sub">操作者：{{item.operatorUid}}</view>
      <view class="sub">变更：{{item.changedFields}}</view>
    </view>
  </block>
</view>
