.share-page {
  padding-bottom: 40rpx;
}

.invite-card {
  background: linear-gradient(135deg, var(--primary), var(--secondary));
  color: #ffffff;
}

.invite-card .title {
  color: #ffffff;
}

.invite-card .sub {
  color: rgba(255, 255, 255, 0.8);
}

.code-display {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.15);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-top: 20rpx;
}

.code-value {
  font-size: 48rpx;
  font-weight: 700;
  letter-spacing: 8rpx;
}

.copy-code-btn {
  background: rgba(255, 255, 255, 0.25);
  color: #ffffff;
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  border-radius: var(--radius-sm);
  border: none;
}

.share-card {
  padding: 32rpx;
}

.list-card {
  padding: 0;
}

.list-card .card-header {
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--border);
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.list-card .card-header .title {
  margin-bottom: 0;
}

.share-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--border);
}

.share-item:last-child {
  border-bottom: none;
}

.share-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary-light), var(--secondary));
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  margin-right: 20rpx;
}

.share-info {
  flex: 1;
}

.share-name {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
  margin-bottom: 8rpx;
}

.share-permission {
  display: flex;
}

.permission-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}

.permission-tag.edit {
  background: rgba(16, 185, 129, 0.1);
  color: var(--success);
}

.permission-tag.view {
  background: rgba(37, 99, 235, 0.1);
  color: var(--primary);
}

.revoke-btn {
  background: transparent;
  color: var(--danger);
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border: 1rpx solid var(--danger);
  border-radius: var(--radius-sm);
}

.empty-state {
  padding: 60rpx 32rpx;
}

.empty-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
  color: var(--text-muted);
}
