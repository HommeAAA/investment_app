<view class="page share-page">
  <view class="card invite-card fade-in">
    <view class="card-header">
      <view class="title">我的邀请码</view>
      <view class="sub">分享给好友即可共享持仓</view>
    </view>
    <view class="code-display">
      <view class="code-value">{{myInviteCode || '--'}}</view>
      <button class="copy-code-btn" bindtap="copyMyCode">复制</button>
    </view>
  </view>

  <view class="card share-card fade-in">
    <view class="card-header">
      <view class="title">发起共享</view>
      <view class="sub">输入对方邀请码建立共享关系</view>
    </view>

    <view class="form-group">
      <view class="form-label">对方邀请码</view>
      <input class="input" placeholder="请输入对方邀请码" value="{{inviteCodeInput}}" bindinput="onInviteCodeInput" />
    </view>

    <view class="form-group">
      <view class="form-label">共享权限</view>
      <picker mode="selector" range="{{permissionOptions}}" bindchange="onPermissionChange" value="{{permissionIndex}}">
        <view class="picker-input">
          <text class="picker-value">{{permissionOptions[permissionIndex]}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>

    <button class="btn btn-primary" bindtap="onInvite" loading="{{loadingInvite}}">
      <text class="btn-icon">🤝</text>
      <text>发起共享</text>
    </button>
  </view>

  <view class="card list-card fade-in">
    <view class="card-header">
      <view class="title">我共享的人</view>
      <view class="badge badge-primary">{{invitedByMe.length}}</view>
    </view>

    <view class="empty-state" wx:if="{{invitedByMe.length === 0}}">
      <view class="empty-icon">📭</view>
      <view class="empty-text">暂无共享记录</view>
    </view>

    <block wx:for="{{invitedByMe}}" wx:key="_id">
      <view class="share-item">
        <view class="share-avatar">
          <text>{{item.targetUser ? item.targetUser.nickname[0] : '?'}}</text>
        </view>
        <view class="share-info">
          <view class="share-name">{{item.targetUser ? item.targetUser.nickname : item.sharedWithUid}}</view>
          <view class="share-permission">
            <text class="permission-tag {{item.permission === 'edit' ? 'edit' : 'view'}}">
              {{item.permission === 'edit' ? '可编辑' : '仅查看'}}
            </text>
          </view>
        </view>
        <button class="revoke-btn" bindtap="onRevoke" data-uid="{{item.sharedWithUid}}">撤销</button>
      </view>
    </block>
  </view>

  <view class="card list-card fade-in">
    <view class="card-header">
      <view class="title">共享给我的人</view>
      <view class="badge badge-success">{{sharedToMe.length}}</view>
    </view>

    <view class="empty-state" wx:if="{{sharedToMe.length === 0}}">
      <view class="empty-icon">📭</view>
      <view class="empty-text">暂无共享记录</view>
    </view>

    <block wx:for="{{sharedToMe}}" wx:key="_id">
      <view class="share-item">
        <view class="share-avatar">
          <text>{{item.ownerUser ? item.ownerUser.nickname[0] : '?'}}</text>
        </view>
        <view class="share-info">
          <view class="share-name">{{item.ownerUser ? item.ownerUser.nickname : item.ownerUid}}</view>
          <view class="share-permission">
            <text class="permission-tag {{item.permission === 'edit' ? 'edit' : 'view'}}">
              {{item.permission === 'edit' ? '可编辑' : '仅查看'}}
            </text>
          </view>
        </view>
      </view>
    </block>
  </view>
</view>
